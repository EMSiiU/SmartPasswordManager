# ============================================================
#  Plantilla de variables de entorno
#  Copia este archivo a ".env" y rellena con valores reales:
#      cp .env.example .env
#  El archivo ".env" esta ignorado por Git: nunca se sube.
# ============================================================

# ---- Base de datos ----
DB_NAME=smartpm
DB_USER=smartpm
DB_PASSWORD=pon_aqui_una_contrasena_fuerte

# ---- JWT ----
# Secreto de firma. DEBE tener al menos 32 caracteres.
# Genera uno aleatorio, por ejemplo con:  openssl rand -base64 48
JWT_SECRET=genera_un_secreto_largo_y_aleatorio_de_al_menos_32_chars
# Tiempo de vida del access token en milisegundos (3600000 = 1 hora)
JWT_EXPIRATION_MS=3600000